{
  "props": [
    {
      "property": "children",
      "type": "ReactNode",
      "required": true,
      "description": "The Radios contained within the RadioGroup."
    },
    {
      "property": "size",
      "type": "'S' | 'M' | 'L' | 'XL'",
      "default": "'M'",
      "description": "The size of the RadioGroup."
    },
    {
      "property": "orientation",
      "type": "Orientation",
      "default": "'vertical'",
      "description": "The axis the radio elements should align with."
    },
    {
      "property": "isEmphasized",
      "type": "boolean",
      "description": "Whether the RadioGroup should be displayed with an emphasized style."
    },
    {
      "property": "styles",
      "type": "StylesProp",
      "description": "Spectrum-defined styles, returned by the `style()` macro.",
      "inheritedFrom": "StyleProps"
    }
  ],
  "status": "stable"
}
